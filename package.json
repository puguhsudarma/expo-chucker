{
  "name": "expo-chucker",
  "version": "1.3.0",
  "description": "Chucker wrapper in expo react native",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "scripts": {
    "reset": "find . -type dir -name node_modules | xargs rm -rfv && watchman watch-del-all && yarn install",
    "build": "expo-module build",
    "clean": "expo-module clean",
    "lint": "expo-module lint",
    "test": "expo-module test",
    "prepare": "expo-module prepare",
    "prepublishOnly": "expo-module prepublishOnly",
    "expo-module": "expo-module",
    "open:ios": "open -a \"Xcode\" example/ios",
    "open:android": "open -a \"Android Studio\" example/android"
  },
  "keywords": [
    "react-native",
    "expo",
    "expo-chucker",
    "chucker"
  ],
  "repository": "https://github.com/puguhsudarma/expo-chucker",
  "bugs": {
    "url": "https://github.com/puguhsudarma/expo-chucker/issues"
  },
  "author": "reroet <wayanpuguhsudarma@gmail.com> (https://github.com/puguhsudarma)",
  "license": "MIT",
  "homepage": "https://github.com/puguhsudarma/expo-chucker#readme",
  "devDependencies": {
    "@types/react": "~18.3.27",
    "expo-module-scripts": "^5.0.8",
    "expo": "~52.0.0",
    "react-native": "0.76.9"
  },
  "peerDependencies": {
    "expo": "*",
    "react": "*",
    "react-native": "*"
  }
}